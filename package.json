{
  "name": "training-generator",
  "private": true,
  "type": "module",
  "description": "Generate phone-first training sessions, publish them to Cloudflare Pages, and log completions locally.",
  "scripts": {
    "postinstall": "node ./scripts/install-free-exercise-db.mjs",
    "test": "node --test tests/docs/*.test.mjs tests/node/*.test.mjs",
    "help": "node ./tools/help_training_generator.mjs",
    "init": "node ./scripts/init-training-generator.mjs",
    "install:exercise-db": "node ./scripts/install-free-exercise-db.mjs",
    "setup:pdf": "npx playwright install chromium",
    "plan:generate": "python3 ./tools/generate_training_plan.py",
    "render:html": "python3 ./tools/render_training_plan.py",
    "render:module-check": "PYTHONPATH=./tools python3 -c \"from training_rendering import render_plan\"",
    "plan:pdf": "node ./tools/export_training_plan_pdf.mjs",
    "artifacts:list": "node ./tools/manage_training_artifacts.mjs",
    "artifacts:delete": "node ./tools/manage_training_artifacts.mjs",
    "html:stage": "node ./tools/stage_training_page_publish.mjs",
    "html:deploy-site": "node ./tools/deploy_cloudflare_pages_site.mjs",
    "html:publish": "node ./tools/publish_html_to_cloudflare.mjs",
    "html:publish:dry-run": "node ./tools/publish_html_to_cloudflare.mjs --dry-run",
    "html:list-published": "node ./tools/publish_html_to_cloudflare.mjs --list-published",
    "html:delete-published": "node ./tools/delete_published_training_page.mjs",
    "state:read": "python3 ./tools/training_state.py read-state",
    "state:read-profile": "python3 ./tools/training_state.py read-profile",
    "state:update-profile": "python3 ./tools/training_state.py update-profile",
    "state:read-feedback-profile": "python3 ./tools/training_state.py read-feedback-profile",
    "state:list-sessions": "python3 ./tools/training_state.py list-sessions",
    "state:read-session": "python3 ./tools/training_state.py read-session",
    "state:update-session": "python3 ./tools/training_state.py update-session",
    "state:update-feedback-profile": "python3 ./tools/training_state.py update-feedback-profile",
    "state:delete-session": "python3 ./tools/training_state.py delete-session",
    "state:list-exercises": "python3 ./tools/training_state.py list-exercises",
    "state:read-exercise": "python3 ./tools/training_state.py read-exercise",
    "state:summarize-context": "python3 ./tools/training_state.py summarize-context",
    "state:validate-log": "python3 ./tools/training_state.py validate-tl1",
    "state:tl1-to-session": "python3 ./tools/training_state.py tl1-to-session",
    "state:eval-plan": "python3 ./tools/training_state.py evaluate-plan"
  },
  "dependencies": {
    "playwright": "1.60.0",
    "qrcode": "^1.5.4"
  }
}
