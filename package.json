{
  "name": "training-generator",
  "private": true,
  "type": "module",
  "description": "Generate phone-first training sessions, publish them to Cloudflare Pages, and log completions locally.",
  "scripts": {
    "test": "node --test tests/docs/*.test.mjs tests/node/*.test.mjs",
    "help": "node ./tools/help_training_generator.mjs",
    "init": "node ./scripts/init-training-generator.mjs",
    "setup:pdf": "npx playwright install chromium",
    "render:html": "python3 ./tools/render_training_plan.py",
    "plan:pdf": "node ./tools/export_training_plan_pdf.mjs",
    "html:publish": "node ./tools/publish_html_to_cloudflare.mjs",
    "html:publish:dry-run": "node ./tools/publish_html_to_cloudflare.mjs --dry-run",
    "html:list-published": "node ./tools/publish_html_to_cloudflare.mjs --list-published",
    "state:read": "python3 ./tools/training_state.py read-state",
    "state:read-profile": "python3 ./tools/training_state.py read-profile",
    "state:list-exercises": "python3 ./tools/training_state.py list-exercises",
    "state:read-exercise": "python3 ./tools/training_state.py read-exercise",
    "state:summarize-context": "python3 ./tools/training_state.py summarize-context",
    "state:validate-log": "python3 ./tools/training_state.py validate-tl1"
  },
  "dependencies": {
    "playwright": "1.60.0",
    "qrcode": "^1.5.4"
  }
}
